<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Revelti Super Admin Navigation</title>
    <script src="https://cdn.tailwindcss.com"></script>

    <!-- Tailwind Configuration -->
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        revelti: {
                            blue: '#213c63',
                            orange: '#f58220',
                            rose: '#be123c'
                        }
                    }
                }
            }
        }
    </script>

    <link rel="stylesheet" href="style.css">
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet">
</head>

<body class="bg-gray-100">

    <nav id="superadmin-main-nav" class="fixed top-0 left-0 right-0 bg-rose-900 shadow-lg z-50 transition-transform duration-300" style="font-family: 'Nunito', sans-serif;">
        <div class="max-w-full mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between items-center h-12">
                <!-- Logo -->
                <div class="flex-shrink-0">
                    <a href="superAdminDashboard.html">
                        <img class="h-5" src="images/reveltiLogoWhite.png" alt="Revelti Logo"
                            onerror="this.onerror=null;this.src='https://placehold.co/120x32/ffffff/be123c?text=revelti';">
                    </a>
                </div>

                <!-- Super Admin View Title (Desktop) -->
                <div class="hidden md:flex items-center">
                    <span class="font-semibold text-sm text-white/80 tracking-wide">SUPER ADMIN VIEW</span>
                </div>

                <!-- Icons -->
                <div class="flex items-center space-x-1">
                    <!-- Platform Status Indicator -->
                    <div class="hidden md:flex items-center space-x-1.5 px-3 py-1 bg-rose-950/60 rounded-full text-xs text-rose-200 mr-2 border border-rose-800/50">
                        <span class="h-2 w-2 rounded-full bg-emerald-500 animate-pulse"></span>
                        <span class="font-semibold">All Systems Live</span>
                    </div>

                    <!-- Hamburger Icon -->
                    <button id="superadmin-hamburger-icon" class="p-1.5 rounded-full hover:bg-white/10" title="Menu">
                        <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                                d="M4 6h16M4 12h16M4 18h16"></path>
                        </svg>
                    </button>
                </div>
            </div>
        </div>

        <!-- Mobile Menu / Account Switcher -->
        <div id="superadmin-mobile-menu"
            class="hidden max-w-full mx-auto px-4 pt-2 pb-4 space-y-2 bg-white border-t border-gray-200 shadow-xl max-h-[80vh] overflow-y-auto">
            <div class="flex items-center justify-end space-x-2 px-2 py-1">
                <span class="font-bold text-rose-600 cursor-pointer">EN</span>
                <span>|</span>
                <span class="font-bold text-gray-700 cursor-pointer">ES</span>
            </div>
            <a href="superAdminDashboard.html"
                class="flex md:hidden items-center justify-end space-x-2 px-2 py-1 text-gray-700 font-semibold hover:bg-gray-100 rounded-md">
                <span>Overview</span>
                <svg class="w-4 h-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 10h16M4 14h16M4 18h16"></path>
                </svg>
            </a>
            <a href="superAdminFinancials.html"
                class="flex md:hidden items-center justify-end space-x-2 px-2 py-1 text-gray-700 font-semibold hover:bg-gray-100 rounded-md">
                <span>Platform Financials</span>
                <svg class="w-4 h-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
            </a>
            <a href="superAdminUsers.html"
                class="flex md:hidden items-center justify-end space-x-2 px-2 py-1 text-gray-700 font-semibold hover:bg-gray-100 rounded-md">
                <span>Users Registry</span>
                <svg class="w-4 h-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
                </svg>
            </a>
            <a href="superAdminEvents.html"
                class="flex md:hidden items-center justify-end space-x-2 px-2 py-1 text-gray-700 font-semibold hover:bg-gray-100 rounded-md">
                <span>Events Moderation</span>
                <svg class="w-4 h-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                </svg>
            </a>
            <a href="superAdminStorage.html"
                class="flex md:hidden items-center justify-end space-x-2 px-2 py-1 text-gray-700 font-semibold hover:bg-gray-100 rounded-md">
                <span>Storage Management</span>
                <svg class="w-4 h-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 7v10a2 2 0 002 2h12a2 2 0 002-2V7a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2zM9 5v4m6-4v4m-8 4h10"></path>
                </svg>
            </a>
            <a href="superAdminModeration.html"
                class="flex md:hidden items-center justify-end space-x-2 px-2 py-1 text-gray-700 font-semibold hover:bg-gray-100 rounded-md">
                <span>Moderation Control</span>
                <svg class="w-4 h-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
                </svg>
            </a>
            
            <div class="border-t border-gray-200 !my-2"></div>
            <div class="px-2 pt-1 text-right text-sm text-gray-500">Back to User Views</div>
            <a href="organizerDashboard.html"
                class="flex items-center justify-end space-x-3 px-2 py-2 text-gray-700 hover:bg-gray-100 rounded-md">
                <div class="text-right">
                    <span class="font-semibold">LMP Events</span>
                    <div class="text-sm text-gray-500">Organizer</div>
                </div>
                <img class="h-10 w-10 rounded-full shadow-md object-cover"
                    src="images/organizerAvatar.png" alt="LMP Events Avatar">
            </a>
            <a href="creativeDashboard.html"
                class="flex items-center justify-end space-x-3 px-2 py-2 text-gray-700 hover:bg-gray-100 rounded-md">
                <div class="text-right">
                    <span class="font-semibold">AMedia</span>
                    <div class="text-sm text-gray-500">Creative</div>
                </div>
                <img class="h-10 w-10 rounded-full shadow-md object-contain bg-black p-1" src="images/creatorLogo.png"
                    alt="AMedia Avatar">
            </a>
            <a href="promoterDashboard.html"
                class="flex items-center justify-end space-x-3 px-2 py-2 text-gray-700 hover:bg-gray-100 rounded-md">
                <div class="text-right">
                    <span class="font-semibold">John Doe</span>
                    <div class="text-sm text-gray-500">Promoter</div>
                </div>
                <img class="h-10 w-10 rounded-full shadow-md object-cover bg-white p-0.5" src="https://placehold.co/80x80/cccccc/000000?text=JD"
                    alt="John Doe Avatar">
            </a>
            <a href="attendeeDashboard.html"
                class="flex items-center justify-end space-x-3 px-2 py-2 text-gray-700 hover:bg-gray-100 rounded-md">
                <div class="text-right">
                    <span class="font-semibold">Alex Johnson</span>
                    <div class="text-sm text-gray-500">Attendee</div>
                </div>
                <img class="h-10 w-10 rounded-full shadow-md object-cover"
                    src="images/attendeeAvatar.png" alt="Alex Johnson Avatar">
            </a>
            <a href="homePage.html?logout=true"
                class="flex items-center justify-end space-x-2 px-2 py-1 text-gray-700 font-semibold hover:bg-gray-100 rounded-md">
                <span>Logout</span>
                <svg class="w-6 h-6 text-rose-800" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                        d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1">
                    </path>
                </svg>
            </a>
        </div>
    </nav>

</body>

</html>
