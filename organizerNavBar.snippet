<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Revelti Organizer Navigation</title>
    <script src="https://cdn.tailwindcss.com"></script>

    <!-- Tailwind Configuration -->
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        revelti: {
                            blue: '#213c63',
                            orange: '#f58220',
                        }
                    }
                }
            }
        }
    </script>

    <link rel="stylesheet" href="style.css">
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet">
</head>

<body class="bg-gray-100">

    <!-- 
  This navbar is designed to be loaded into a placeholder div, 
  for example: <div id="organizer-navbar-placeholder"></div> 
-->

    <nav id="organizer-main-nav" class="fixed top-0 left-0 right-0 bg-revelti-blue shadow-md z-50 transition-transform duration-300" style="font-family: 'Nunito', sans-serif;">
        <div class="max-w-full mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between items-center h-12">
                <!-- Logo -->
                <div class="flex-shrink-0">
                    <a href="organizerDashboard.html">
                        <!-- Using the white text version of the logo -->
                        <img class="h-5" src="images/reveltiLogoWhite.png" alt="Revelti Logo"
                            onerror="this.onerror=null;this.src='https://placehold.co/120x32/ffffff/213c63?text=revelti';">
                    </a>
                </div>

                <!-- Organizer View Title (Desktop) -->
                <div class="hidden md:flex items-center">
                    <span class="font-semibold text-sm text-white/80 tracking-wide">ORGANIZER VIEW</span>
                </div>

                <!-- Icons -->
                <div class="flex items-center space-x-0">
                    <!-- Notification Icon -->
                    <a href="organizerNotifications.html" class="p-1.5 rounded-full hover:bg-white/20"
                        title="Organizer Notifications" data-no-active-link>
                        <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                                d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9">
                            </path>
                        </svg>
                    </a>
                    <!-- Hamburger Icon -->
                    <button id="organizer-hamburger-icon" class="p-1.5 rounded-full hover:bg-white/20">
                        <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                                d="M4 6h16M4 12h16M4 18h16"></path>
                        </svg>
                    </button>
                </div>
            </div>
        </div>

        <!-- Mobile Menu -->
        <div id="organizer-mobile-menu"
            class="hidden max-w-full mx-auto px-4 pt-2 pb-4 space-y-2 bg-white border-t border-gray-200 max-h-[80vh] overflow-y-auto">
            <div class="flex items-center justify-end space-x-2 px-2 py-1">
                <span id="organizer-lang-en" class="font-bold revelti-orange cursor-pointer">EN</span>
                <span>|</span>
                <span id="organizer-lang-es" class="font-bold text-gray-700 cursor-pointer">ES</span>
            </div>
            <a href="organizerDashboard.html"
                class="flex items-center justify-end space-x-2 px-2 py-1 text-gray-700 font-semibold hover:bg-gray-100 rounded-md"><span>Dashboard</span></a>
            <a href="createEvent.html"
                class="flex items-center justify-end space-x-2 px-2 py-1 text-gray-700 font-semibold hover:bg-gray-100 rounded-md"><span>Create Event</span></a>
            <a href="organizerMediaWorkspace.html"
                class="flex md:hidden items-center justify-end space-x-2 px-2 py-1 text-gray-700 font-semibold hover:bg-gray-100 rounded-md">
                <span>Media Workspace</span>
                <svg class="w-4 h-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                </svg>
            </a>
            <a href="organizerEmails.html"
                class="flex md:hidden items-center justify-end space-x-2 px-2 py-1 text-gray-700 font-semibold hover:bg-gray-100 rounded-md">
                <span>Emails</span>
                <svg class="w-4 h-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                </svg>
            </a>
            <a href="creatorsOverview.html"
                class="flex md:hidden items-center justify-end space-x-2 px-2 py-1 text-gray-700 font-semibold hover:bg-gray-100 rounded-md">
                <span>Creators</span>
                <svg class="w-4 h-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"></path>
                </svg>
            </a>
            <a href="promotersOverview.html"
                class="flex md:hidden items-center justify-end space-x-2 px-2 py-1 text-gray-700 font-semibold hover:bg-gray-100 rounded-md">
                <span>Promoters</span>
                <svg class="w-4 h-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z"></path>
                </svg>
            </a>
            <a href="financialOverview.html"
                class="flex md:hidden items-center justify-end space-x-2 px-2 py-1 text-gray-700 font-semibold hover:bg-gray-100 rounded-md">
                <span>Financial Overview</span>
                <svg class="w-4 h-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 12l3-3 3 3 4-4M8 21l4-4 4 4M3 4h18M4 4h16v12a1 1 0 01-1 1H5a1 1 0 01-1-1V4z"></path>
                </svg>
            </a>
            <a href="incomeBreakdown.html"
                class="flex md:hidden items-center justify-end space-x-2 px-2 py-1 text-gray-700 font-semibold hover:bg-gray-100 rounded-md">
                <span>Income Breakdown</span>
                <svg class="w-4 h-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
            </a>
            <a href="ticketBreakdown.html"
                class="flex md:hidden items-center justify-end space-x-2 px-2 py-1 text-gray-700 font-semibold hover:bg-gray-100 rounded-md">
                <span>Ticket Sales</span>
                <svg class="w-4 h-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"></path>
                </svg>
            </a>
            <a href="organizerSettings.html"
                class="flex md:hidden items-center justify-end space-x-2 px-2 py-1 text-gray-700 font-semibold hover:bg-gray-100 rounded-md">
                <span>Settings</span>
                <svg class="w-4 h-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                </svg>
            </a>
            <div class="border-t border-gray-200 !my-2"></div>
            <div class="px-2 pt-1 text-right text-sm text-gray-500">Switch accounts</div>
            <a href="attendeeDashboard.html"
                class="flex items-center justify-end space-x-3 px-2 py-2 text-gray-700 hover:bg-gray-100 rounded-md">
                <div class="text-right">
                    <span class="font-semibold">Alex Johnson</span>
                    <div class="text-sm text-gray-500">Attendee</div>
                </div>
                <img class="h-10 w-10 rounded-full shadow-md object-cover"
                    src="images/attendeeAvatar.png" alt="Alex Johnson Avatar">
            </a>
            <a href="creativeDashboard.html"
                class="flex items-center justify-end space-x-3 px-2 py-2 text-gray-700 hover:bg-gray-100 rounded-md">
                <div class="text-right">
                    <span class="font-semibold">AMedia</span>
                    <div class="text-sm text-gray-500">Creative</div>
                </div>
                <img class="h-10 w-10 rounded-full shadow-md object-contain bg-black p-1" src="images/creatorLogo.png"
                    alt="AMedia Avatar"
                    onerror="this.onerror=null;this.src='https://placehold.co/80x80/213c63/ffffff?text=AM';">
            </a>
            <a href="promoterDashboard.html"
                class="flex items-center justify-end space-x-3 px-2 py-2 text-gray-700 hover:bg-gray-100 rounded-md">
                <div class="text-right">
                    <span class="font-semibold">John Doe</span>
                    <div class="text-sm text-gray-500">Promoter</div>
                </div>
                <img class="h-10 w-10 rounded-full shadow-md object-cover bg-white p-0.5" src="https://placehold.co/80x80/cccccc/000000?text=JD"
                    alt="John Doe Avatar">
            </a>
            <a href="superAdminDashboard.html"
                class="flex items-center justify-end space-x-3 px-2 py-2 text-gray-700 hover:bg-gray-100 rounded-md">
                <div class="text-right">
                    <span class="font-semibold">Platform Admin</span>
                    <div class="text-sm text-gray-500">Super Admin</div>
                </div>
                <div class="h-10 w-10 rounded-full bg-rose-100 flex items-center justify-center font-bold text-rose-800 text-sm shadow-md">SA</div>
            </a>
            <a href="homePage.html?logout=true"
                class="flex items-center justify-end space-x-2 px-2 py-1 text-gray-700 font-semibold hover:bg-gray-100 rounded-md">
                <span>Logout</span>
                <svg class="w-6 h-6 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                        d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1">
                    </path>
                </svg>
            </a>
        </div>
    </nav>

</body>

</html>